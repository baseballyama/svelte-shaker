pnpm-lock.yaml

# The site has its own SvelteKit toolchain (and .svelte files need the svelte
# prettier plugin); it is formatted/checked independently of the engine.
packages/site/**

packages/svelte-shaker/tests/fixtures/**

# Transient compiled output from the differential-SSR oracle (tests/diff.ts) and
# the end-to-end build suites.  The oracle namespaces its dir per worker
# (`.shaker-tmp-<workerId>`) to avoid cross-worker races, and the build suites use
# `.shaker-tmp-vite` / `.shaker-tmp-css`; the glob below covers them all.  Normally
# removed by `cleanTmp()` / `afterAll`, but may linger if a run is interrupted —
# never format it.
packages/svelte-shaker/tests/.shaker-tmp*/**
