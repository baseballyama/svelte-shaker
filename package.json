{
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "build": "pnpm --filter svelte-shaker build",
    "test": "pnpm --filter svelte-shaker test",
    "release": "changeset publish",
    "all:check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "all:fix": "pnpm lint:fix && pnpm format:fix"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "vitest": "1.6.1"
  },
  "engines": {
    "node": ">=22.23.1",
    "pnpm": ">=11.15.1"
  },
  "packageManager": "pnpm@11.15.1"
}
