{
  "name": "svelte-shaker-engine-scan-native",
  "version": "0.3.0",
  "description": "Native (napi) engine for svelte-shaker: parses with rsvelte and runs the whole-program shake (a long-lived ShakeSession) in-process, so no AST crosses the JS boundary.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/svelte-shaker.git",
    "directory": "packages/svelte-shaker/engine-scan-native"
  },
  "files": [
    "index.cjs",
    "index.d.ts",
    "*.node"
  ],
  "main": "index.cjs",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "cargo build --release",
    "build:debug": "cargo build"
  },
  "engines": {
    "node": ">=22.23.1"
  }
}
