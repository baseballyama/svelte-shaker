{
  "name": "svelte-shaker",
  "version": "0.12.0",
  "description": "Tree shaking for Svelte components",
  "keywords": [
    "dead-code-elimination",
    "rollup",
    "svelte",
    "tree-shaker",
    "tree-shaking",
    "vite-plugin"
  ],
  "homepage": "https://github.com/baseballyama/svelte-shaker#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/svelte-shaker/issues"
  },
  "license": "MIT",
  "author": "baseballyama",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/svelte-shaker.git",
    "directory": "packages/svelte-shaker"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./node": {
      "types": "./dist/scan.d.ts",
      "import": "./dist/scan.js",
      "default": "./dist/scan.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-wasm.mjs",
    "build:wasm": "wasm-pack build engine-rs --target nodejs --release --out-dir pkg",
    "prepack": "tsc -p tsconfig.build.json && node scripts/copy-wasm.mjs",
    "dev": "tsc -p tsconfig.build.json -w",
    "test:watch": "vitest",
    "test": "vitest run"
  },
  "dependencies": {
    "magic-string": "0.30.21",
    "zimmerframe": "1.1.4"
  },
  "devDependencies": {
    "@rsvelte/compiler": "0.6.1",
    "@rsvelte/vite-plugin-svelte-native": "0.2.6",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "svelte": "^5.56.6",
    "vite": "^5.4.21"
  },
  "peerDependencies": {
    "@rsvelte/vite-plugin-svelte-native": ">=0.2.6",
    "svelte": "^5.56.6"
  },
  "peerDependenciesMeta": {
    "@rsvelte/vite-plugin-svelte-native": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
