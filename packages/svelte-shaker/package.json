{
  "name": "svelte-shaker",
  "version": "0.0.1",
  "description": "Tree shaking for Svelte components",
  "author": "baseballyama",
  "license": "MIT",
  "keywords": [
    "svelte",
    "tree-shaking",
    "tree-shaker",
    "vite-plugin",
    "rollup-plugin",
    "dead-code-elimination"
  ],
  "homepage": "https://github.com/baseballyama/svelte-shaker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/svelte-shaker.git",
    "directory": "packages/svelte-shaker"
  },
  "bugs": {
    "url": "https://github.com/baseballyama/svelte-shaker/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/types/src/index.d.ts",
  "files": [
    "dist/*.js",
    "dist/*.cjs",
    "dist/types/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/types/src/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./node": {
      "types": "./dist/types/src/scan.d.ts",
      "import": "./dist/scan.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c",
    "prepack": "rollup -c",
    "dev": "rollup -cw",
    "test:watch": "vitest",
    "test": "vitest run"
  },
  "dependencies": {
    "magic-string": "0.30.10",
    "zimmerframe": "1.1.2"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "25.0.8",
    "@rollup/plugin-node-resolve": "15.2.3",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "11.1.6",
    "@sveltejs/vite-plugin-svelte": "^4",
    "rollup": "4.18.0",
    "svelte": "^5",
    "tslib": "2.6.2",
    "vite": "^5"
  }
}
