{
  "name": "svelte-shaker",
  "version": "0.16.1",
  "description": "Tree shaking for Svelte components",
  "keywords": [
    "dead-code-elimination",
    "rollup",
    "svelte",
    "tree-shaker",
    "tree-shaking",
    "vite-plugin"
  ],
  "homepage": "https://github.com/baseballyama/svelte-shaker#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/svelte-shaker/issues"
  },
  "license": "MIT",
  "author": "baseballyama",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/svelte-shaker.git",
    "directory": "packages/svelte-shaker"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./node": {
      "types": "./dist/scan.d.ts",
      "import": "./dist/scan.js",
      "default": "./dist/scan.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-wasm.mjs",
    "build:wasm": "wasm-pack build engine-rs --target nodejs --release --out-dir pkg",
    "prepack": "tsc -p tsconfig.build.json && node scripts/copy-wasm.mjs",
    "dev": "tsc -p tsconfig.build.json -w",
    "test:watch": "vitest",
    "test": "vitest run"
  },
  "dependencies": {
    "@rsvelte/compiler": "0.8.1",
    "magic-string": "1.0.0",
    "picomatch": "4.0.5",
    "zimmerframe": "1.1.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/picomatch": "4.0.2",
    "svelte": "^5.56.6",
    "vite": "^8.1.5"
  },
  "peerDependencies": {
    "svelte": "^5.56.6"
  },
  "optionalDependencies": {
    "svelte-shaker-engine-scan-native": "~0.2.0"
  },
  "engines": {
    "node": ">=22.23.1"
  }
}
